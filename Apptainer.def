Bootstrap: docker
From: ghcr.io/nvidia/jax:equinox-2025-01-15 
%labels
  Author: cdetts
  Description: Neural CDE for TTS - LJSpeech feature extraction and training

%post
  pip install diffrax

  # Install system dependencies
    # Enable universe repo for ffmpeg
  apt-get update && apt-get install -y --no-install-recommends software-properties-common
  add-apt-repository universe
  apt-get update && apt-get install -y --no-install-recommends \
      ffmpeg \
      libavutil-dev \
      libavcodec-dev \
      libavformat-dev \
      espeak-ng \
      libespeak-ng-dev \
      build-essential \
      python3-dev \
  && rm -rf /var/lib/apt/lists/* && rm -rf /var/lib/apt/lists/*


  # Install Python dependencies (torch, matcha requirements, and training deps)
    pip install --no-cache-dir \
        torch \
        torchvision \
        torchaudio \
        lightning \
        torchmetrics \
        hydra-core==1.3.2 \
        hydra-colorlog==1.2.0 \
        hydra-optuna-sweeper==1.2.0 \
        rootutils \
        rich \
        pytest \
        phonemizer \
        tensorboard \
        librosa \
        Cython \
        numpy \
        einops \
        inflect \
        Unidecode \
        scipy \
        matplotlib \
        pandas \
        conformer==0.3.2 \
        diffusers \
        notebook \
        ipywidgets \
        gradio==3.43.2 \
        gdown \
        wget \
        seaborn \
        pyyaml \
        torchcodec \
        transformers \

    pip install numpy==2.4.4

%files

%runscript
    exec "$@"

%help
    To rebuild monotonic_align (if needed):
    python /home/acq22mc/cdetts/setup_monotonic_align.py
